---
const phone = '(417) 555-0198';
const email = 'quotes@springfieldlotstriping.com';
---

<footer class="bg-primary-dark text-white/90 pt-12 pb-8">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <img src="/images/logo-final-v2.png" alt="Springfield Lot Striping" class="h-16 w-auto" />
        <span class="text-white font-semibold text-xl">Springfield Lot Striping</span>
      </div>
      <p class="text-sm text-white/70">Commercial parking lot striping and ADA compliance for Springfield and Greene County businesses.</p>
      <p class="text-xs text-white/60 mt-2">1245 N Glenstone Ave<br>Springfield, MO 65802</p>
    </div>

    <div>
      <div class="uppercase tracking-[0.18em] text-xs text-brand-yellow mb-3">Contact (Temporary)</div>
      <div class="space-y-1 text-sm">
        <a href="tel:+141****0198" class="block hover:text-brand-yellow transition-colors">{phone}</a>
        <a href="mailto:" class="block hover:text-brand-yellow transition-colors">{email}</a>
      </div>
      <div class="mt-4 text-sm text-white/70">
        Same-week availability • Greene County focus
      </div>
    </div>

    <div>
      <div class="uppercase tracking-[0.18em] text-xs text-brand-yellow mb-3">Top Pages</div>
      <ul class="space-y-1 text-sm">
        <li><a href="/services/parking-lot-striping" class="hover:text-brand-yellow transition-colors">Parking Lot Striping</a></li>
        <li><a href="/services/ada-compliance-striping" class="hover:text-brand-yellow transition-colors">ADA Compliance Striping</a></li>
        <li><a href="/services/fire-lane-striping" class="hover:text-brand-yellow transition-colors">Fire Lane Striping</a></li>
        <li><a href="/service-area/springfield-mo" class="hover:text-brand-yellow transition-colors">Springfield Service Area</a></li>
        <li><a href="/contact" class="hover:text-brand-yellow transition-colors">Request a Quote</a></li>
      </ul>
    </div>
  </div>

  <div class="mt-12 border-t border-white/10 pt-6 text-center text-xs text-white/60 max-w-7xl mx-auto px-6">
    © {new Date().getFullYear()} Springfield Lot Striping. Commercial pavement marking services in Springfield, MO and Greene County. All rights reserved. <span class="text-[10px] opacity-70">(Temporary contact info - will be updated with operator details)</span>
  </div>
</footer>
