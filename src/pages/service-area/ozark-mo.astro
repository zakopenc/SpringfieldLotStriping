---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

const title = "Parking Lot Striping in Ozark MO | Commercial Line Striping Services";
const description = "Reliable commercial parking lot striping for Ozark, Missouri businesses. ADA markings, fire lanes, warehouse safety lines serving Christian County.";
const h1 = "Parking Lot Striping in Ozark, Missouri";
---

<BaseLayout {title} {description}>
  <Header />
  <div class="pt-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <h1 class="text-5xl font-bold text-primary-dark">{h1}</h1>
      <div class="text-brand-yellow text-xl mt-2">Christian County • Fast Local Service</div>
      
      <img src="/images/xai_grok-imagine-image_20260623_174828_ea9e8b9b.jpg" alt="Ozark commercial parking lot" class="my-12 rounded-2xl shadow-xl w-full" />
      
      <div class="prose prose-lg max-w-none text-concrete">
        <p>Our team serves commercial properties throughout Ozark, Missouri with professional parking lot striping, ADA compliance markings, and fire lane painting. We frequently work in the industrial parks off Highway 65 and the retail corridors near the Ozark Square.</p>
        
        <p>Ozark facility managers rely on us for reliable, code-compliant work that minimizes disruption to their tenants and customers. Whether you manage a shopping center, office park, or light industrial facility, we deliver lasting results that protect your property and your liability.</p>
        
        <p><a href="/services/ada-compliance-striping" class="text-brand-yellow hover:underline font-medium">Learn about our ADA compliance services in Ozark →</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
