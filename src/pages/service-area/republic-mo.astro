---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

const title = "Parking Lot Striping in Republic MO | Commercial & ADA Services";
const description = "Professional parking lot striping, restriping, and ADA compliance for businesses in Republic, Missouri and western Greene County.";
const h1 = "Parking Lot Striping in Republic, Missouri";
---

<BaseLayout {title} {description}>
  <Header />
  <div class="pt-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <h1 class="text-5xl font-bold text-primary-dark">{h1}</h1>
      <div class="text-brand-yellow text-xl mt-2">Western Greene County Specialist</div>
      
      <img src="/images/xai_grok-imagine-image_20260623_180942_d5ed3477.jpg" alt="Republic MO parking lot" class="my-12 rounded-2xl shadow-xl w-full" />
      
      <div class="prose prose-lg max-w-none text-concrete">
        <p>We proudly serve the growing commercial sector in Republic, Missouri. From the industrial areas along US Highway 60 to the retail developments near the Republic Airport, our team provides high-quality parking lot striping that meets all current ADA and fire safety standards.</p>
        
        <p>Republic property owners and facility managers appreciate our fast response times, competitive pricing, and professional documentation. We understand the specific needs of this fast-growing southwest Springfield suburb.</p>
        
        <p><a href="/services/fire-lane-striping" class="text-brand-yellow hover:underline font-medium">See our fire lane and safety striping services →</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
