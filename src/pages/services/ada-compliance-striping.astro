---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const title = "ADA Parking Lot Striping Springfield MO | Handicap Compliance Markings";
const description = "Expert ADA compliant parking lot striping in Springfield, Missouri. Avoid fines up to $75,000. Full compliance packages with proper dimensions and signage.";
const h1 = "ADA-Compliant Parking Lot Markings in Springfield, MO";
---

<ServiceLayout {title} {description} {h1}>
  <div class="prose prose-lg max-w-none">
    <p class="text-xl leading-relaxed">Missouri commercial properties face fines of up to <strong>$75,000 per violation</strong> for non-compliant ADA parking. We ensure your lot meets both federal ADA standards and Missouri accessibility requirements.</p>
    
    <img src="/images/xai_grok-imagine-image_20260623_174834_8c90e1f0.jpg" alt="ADA compliant parking markings" class="my-12 rounded-2xl shadow-2xl w-full" />
    
    <h2 class="text-3xl font-semibold text-primary-dark mt-12">What ADA Compliance Includes</h2>
    <ul class="list-disc pl-6 space-y-3 text-lg">
      <li>Correct number of accessible spaces based on total parking</li>
      <li>Proper stall dimensions and van-accessible spaces</li>
      <li>Level access aisles with correct slope</li>
      <li>International Symbol of Accessibility signage at correct height</li>
      <li>Documentation and before/after photos for your records</li>
    </ul>

    <div class="bg-surface p-10 rounded-3xl my-12">
      <p class="font-semibold text-xl text-center">Protect your property from costly ADA violations.<br>Get a free compliance assessment today.</p>
    </div>
  </div>
</ServiceLayout>
