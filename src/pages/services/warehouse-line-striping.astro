---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const title = "Warehouse Line Striping Springfield MO | Industrial Floor Markings";
const description = "Professional warehouse and loading dock line striping in Springfield, Missouri. Forklift lanes, safety zones, and dock approach markings for distribution centers.";
const h1 = "Warehouse & Loading Dock Line Striping in Springfield, MO";
---

<ServiceLayout {title} {description} {h1}>
  <div class="prose prose-lg max-w-none">
    <p class="text-xl">We specialize in professional warehouse and industrial floor marking for distribution centers, manufacturing facilities, and large commercial buildings throughout Springfield and Greene County.</p>
    
    <img src="/images/xai_grok-imagine-image_20260623_180942_d5ed3477.jpg" alt="Warehouse line striping" class="my-12 rounded-2xl shadow-xl" />
    
    <h2>Our Warehouse Striping Services</h2>
    <ul>
      <li>Forklift lanes and pedestrian walkways</li>
      <li>Loading dock approach markings</li>
      <li>Safety zones and hazard areas</li>
      <li>5S and lean manufacturing markings</li>
      <li>OSHA-compliant safety lines</li>
    </ul>
    
    <p>Our warehouse markings use high-durability epoxy and thermoplastic materials designed to withstand heavy forklift traffic, chemical exposure, and frequent cleaning.</p>
    
    <p class="text-brand-yellow font-medium mt-12">Need warehouse safety lines installed or refreshed in Springfield? Contact us for a free facility assessment.</p>
  </div>
</ServiceLayout>
