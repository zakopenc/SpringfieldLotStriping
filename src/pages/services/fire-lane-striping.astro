---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const title = "Fire Lane Striping Springfield MO | NFPA Compliant Markings";
const description = "Professional fire lane striping and red curb painting in Springfield, Missouri. NFPA compliant, clear lettering, and regulatory markings for commercial properties.";
const h1 = "Fire Lane Striping in Springfield, Missouri";
---

<ServiceLayout {title} {description} {h1}>
  <div class="prose prose-lg max-w-none">
    <p class="lead">We provide code-compliant fire lane striping that meets all NFPA and local fire marshal requirements. Bright red curbs with bold white lettering help protect your property and keep you in compliance.</p>
    
    <img src="/images/xai_grok-imagine-image_20260623_174841_36a1fcb1.jpg" alt="Fire lane striping" class="rounded-2xl my-10 shadow-xl" />
    
    <h2>Our Fire Lane Services Include:</h2>
    <ul>
      <li>NFPA-compliant red curb painting</li>
      <li>"NO PARKING — FIRE LANE" lettering</li>
      <li>Loading zone and fire access markings</li>
      <li>Annual refresh and maintenance programs</li>
    </ul>
  </div>
</ServiceLayout>
