---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const title = "Parking Lot Striping Springfield MO | Commercial Line Striping Company";
const description = "Expert commercial parking lot striping in Springfield, Missouri. Restriping, new layouts, arrows, crosswalks and more. Fast professional service.";
const h1 = "Parking Lot Striping Services in Springfield, Missouri";
---

<ServiceLayout {title} {description} {h1}>
  <div class="prose prose-lg max-w-none">
    <p class="text-xl text-concrete">We provide professional commercial parking lot striping throughout Springfield and all of Greene County. From standard stall layouts to complex new designs, our team delivers crisp, long-lasting results that meet or exceed industry standards.</p>
    
    <h2 class="text-3xl font-semibold text-primary-dark mt-16">What We Stripe</h2>
    <ul class="grid md:grid-cols-2 gap-x-12 gap-y-3 text-lg">
      <li>✓ Parking stalls &amp; drive aisles</li>
      <li>✓ Handicap spaces &amp; access aisles</li>
      <li>✓ Fire lanes &amp; no-parking zones</li>
      <li>✓ Crosswalks &amp; directional arrows</li>
      <li>✓ Loading zones &amp; curbs</li>
      <li>✓ Warehouse safety lines</li>
    </ul>

    <h2 class="text-3xl font-semibold text-primary-dark mt-16">Our 4-Step Process</h2>
    <div class="grid md:grid-cols-4 gap-8 mt-10">
      <div class="text-center">
        <div class="text-5xl font-mono text-brand-yellow mb-4">01</div>
        <h3 class="font-semibold">Measure &amp; Layout</h3>
      </div>
      <div class="text-center">
        <div class="text-5xl font-mono text-brand-yellow mb-4">02</div>
        <h3 class="font-semibold">Surface Prep</h3>
      </div>
      <div class="text-center">
        <div class="text-5xl font-mono text-brand-yellow mb-4">03</div>
        <h3 class="font-semibold">Professional Striping</h3>
      </div>
      <div class="text-center">
        <div class="text-5xl font-mono text-brand-yellow mb-4">04</div>
        <h3 class="font-semibold">Final Inspection</h3>
      </div>
    </div>

    <img src="/images/xai_grok-imagine-image_20260623_180927_63d294da.jpg" alt="Freshly restriped commercial parking lot" class="my-12 rounded-2xl shadow-xl" />

    <h2 class="text-3xl font-semibold text-primary-dark mt-16">Pricing Ranges (Springfield, MO)</h2>
    <p class="text-concrete">Restriping: $0.85 – $2.25 per stall • Full layouts: $1,200 – $4,500+ • ADA packages quoted separately. We provide transparent, competitive pricing with no hidden fees.</p>
  </div>
</ServiceLayout>
