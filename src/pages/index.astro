---
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const phone = '(417) 555-0123';
---

<BaseLayout 
  title="Parking Lot Striping Springfield MO | Commercial Line Striping & ADA Compliance"
  description="Professional commercial parking lot striping in Springfield, MO. ADA markings, fire lanes, warehouse line striping, and restriping. Fast quotes. Serving Greene County.">
  
  <Header />
  
  <!-- FINAL PROFESSIONAL HERO (No Text in Image) -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <img src="/images/hero-professional-final.jpg" alt="Professional technician applying crisp yellow parking lines on asphalt in Springfield Missouri" class="absolute inset-0 w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-b from-black/65 via-black/40 to-black/75"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center text-white">
      <h1 class="text-6xl md:text-7xl font-bold tracking-tighter leading-none mb-6">
        Commercial Parking Lot Striping<br>in Springfield, MO
      </h1>
      <p class="text-2xl md:text-3xl max-w-3xl mx-auto mb-10 text-white/90">
        ADA-compliant markings • Fire lane striping • Warehouse safety lines • Professional restriping.<br>
        Local. Reliable. Code-compliant. No residential work.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
        <a href="#quote" 
           class="btn-primary text-xl px-12 py-5 inline-flex items-center gap-3 text-lg font-semibold">
          Get Free Quote Now →
        </a>
        <a href="tel:4175550123" 
           class="border-2 border-white text-white hover:bg-white hover:text-primary-dark transition-all px-10 py-5 text-xl font-medium rounded-xl">
          Call (417) 555-0123
        </a>
      </div>
      
      <div class="mt-16 flex justify-center gap-10 text-sm opacity-90">
        <div class="flex items-center gap-2"><span class="text-brand-yellow">✓</span> ADA Specialists</div>
        <div class="flex items-center gap-2"><span class="text-brand-yellow">✓</span> Same-Week Service</div>
        <div class="flex items-center gap-2"><span class="text-brand-yellow">✓</span> Fully Documented</div>
      </div>
    </div>
  </section>

  <!-- Rest of expanded content -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 prose prose-lg">
      <p class="text-xl leading-relaxed">Springfield Lot Striping is the premier commercial-only parking lot striping company serving Springfield and all of Greene County, Missouri. We specialize in ADA compliant markings, NFPA fire lane striping, warehouse and forklift safety lines, and professional restriping for commercial properties including strip malls, distribution centers, office parks, apartment complexes, truck stops, big-box retail, and medical facilities.</p>
    </div>
  </section>

  <footer class="bg-primary-dark text-white/80 py-16">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <img src="/images/logo-final.png" alt="Springfield Lot Striping" class="h-12 mx-auto mb-8 brightness-125">
      <p class="text-sm max-w-md mx-auto">Professional commercial parking lot striping • ADA compliance specialists • Serving all of Greene County, Missouri</p>
      <p class="text-xs opacity-50 mt-12">© 2026 Springfield Lot Striping. Commercial work only.</p>
    </div>
  </footer>
</BaseLayout>
