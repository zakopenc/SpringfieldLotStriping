---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteUrl = Astro.site?.toString() ?? 'https://www.springfieldlotstriping.com';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const defaultImage = new URL('/images/hero-professional-final.jpg', siteUrl).toString();
const pageTitle = `${title}`;

// Contact details will be updated with real operator info when available
const contactPhone = 'Request quote for immediate callback'; // Temporary - real operator phone will replace
const contactTel = ''; // Use quote form or email for callback
const contactEmail = 'quotes@springfieldlotstriping.com';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}#business`,
      name: 'Springfield Lot Striping',
      description: 'Commercial parking lot striping and ADA compliance marking services in Springfield, MO and Greene County.',
      url: siteUrl,
      email: contactEmail,
      image: defaultImage,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Springfield, MO',
        addressLocality: 'Springfield',
        addressRegion: 'MO',
        postalCode: '65802',
        addressCountry: 'US'
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 37.2090,
        longitude: -93.2923
      },
      areaServed: [
        { '@type': 'City', name: 'Springfield', addressRegion: 'MO' },
        { '@type': 'City', name: 'Nixa', addressRegion: 'MO' },
        { '@type': 'City', name: 'Ozark', addressRegion: 'MO' },
        { '@type': 'City', name: 'Republic', addressRegion: 'MO' },
        { '@type': 'City', name: 'Battlefield', addressRegion: 'MO' },
        { '@type': 'City', name: 'Rogersville', addressRegion: 'MO' },
        { '@type': 'AdministrativeArea', name: 'Greene County', addressRegion: 'MO' }
      ],
      serviceType: ['Parking Lot Striping', 'ADA Compliance Striping', 'Fire Lane Striping', 'Warehouse Line Striping', 'Restriping'],
      priceRange: '$$',
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Commercial Parking Lot Striping Services',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Parking Lot Striping' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'ADA Compliance Striping' } }
        ]
      }
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'Springfield Lot Striping',
      description: description,
      inLanguage: 'en-US'
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Springfield Lot Striping" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={defaultImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={defaultImage} />
  <title>{title}</title>
  <link rel="canonical" href={canonical} />
  <link rel="alternate" href={canonical} hreflang="en-us" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9HFMJXJZSM"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9HFMJXJZSM');
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="180x180" href="/favicon-180.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
</head>
<body class="bg-surface text-concrete antialiased">
  <slot />
  <Footer />
</body>
</html>