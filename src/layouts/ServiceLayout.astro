---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  h1: string;
}

const { title, description, h1 } = Astro.props;
---

<BaseLayout {title} {description}>
  <Header />
  
  <div class="pt-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <h1 class="text-5xl font-bold text-primary-dark mb-8">{h1}</h1>
      <div class="stripe-divider w-20 h-1 bg-brand-yellow mb-12"></div>
      
      <slot />
    </div>
  </div>

  <!-- CTA Banner -->
  <div class="bg-primary-dark py-16 text-white text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-4xl font-semibold mb-4">Ready for Professional Striping?</h2>
      <p class="text-xl mb-8 text-white/80">Get a free quote for your Springfield or Greene County property today.</p>
      <a href="/#quote" class="btn-primary text-lg px-12 py-4 inline-block">Request Free Quote →</a>
    </div>
  </div>
  
  <script>
    // Simple accordion enhancement if needed
  </script>
</BaseLayout>
